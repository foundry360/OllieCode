# Copy to .env.local for local development (never commit secrets).

# Supabase — create a project at https://supabase.com (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Legacy anon key (API Keys → Legacy) or new publishable key as NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only — parent approval + account creation (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Synthetic login email for username accounts: {username}@{NEXT_PUBLIC_AUTH_EMAIL_DOMAIN}
NEXT_PUBLIC_AUTH_EMAIL_DOMAIN=users.olliecode.app
# Encrypts pending signup passwords server-side (min 16 characters)
PENDING_SIGNUP_SECRET=use-a-long-random-string-here

# Optional — parent approval email (Resend works out of the box with the values below).
# If any of these are unset, signup still works: the success screen shows an approval URL to share manually.
#
# Resend: https://resend.com → API Keys → create key. Domains → add your domain (or use onboarding@resend.dev for dev only).
EMAIL_API_URL=https://api.resend.com/emails
EMAIL_API_KEY=
# Example dev: Ollie Code <onboarding@resend.dev>  |  production: Ollie Code <noreply@yourdomain.com>
EMAIL_FROM=

# Inbound contact form: where visitor messages are delivered (Resend “to” address).
CONTACT_INBOX_EMAIL=

# Shown in the contact form if the server cannot send email (optional but recommended).
NEXT_PUBLIC_SUPPORT_EMAIL=

# Authentication → URL Configuration:
#   Site URL: http://localhost:3000 (production: your deployed origin)
#   Redirect URLs: http://localhost:3000/auth/callback (and production /auth/callback)

# Storage: private bucket named `projects`; policies scoped to auth.uid() path prefix (see README).

# Stripe — https://dashboard.stripe.com/apikeys (use test keys in dev). Each value is a Price ID (price_…), not a Product ID.
#
# Catalog layout (match Starter to Family): **one Product per plan**, each with **two recurring prices**
# (month + year). In Dashboard → Product catalog → open “Starter” → Add price → recurring monthly;
# Add another price → recurring yearly. Paste both price_… IDs below. Avoid a separate Product per
# interval for the same plan. Verify: `npm run stripe:verify-catalog` (loads .env.local).
STRIPE_SECRET_KEY=
# Publishable key (pk_test_… / pk_live_…) — required for in-modal Checkout (Elements) on the workspace paywall.
# Fine-tune Payment Element colors via code (`workspace-plan-checkout-form`) and Stripe Dashboard → Branding.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Recommended in production so Checkout return URLs match your domain (e.g. https://olliecode.app).
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_FAMILY_MONTHLY=
STRIPE_PRICE_FAMILY_YEARLY=
# Webhook signing secret (Developers → Webhooks → your endpoint → Signing secret).
# Endpoint URL: https://YOUR_DOMAIN/api/stripe/webhook — listen for checkout.session.completed,
# customer.subscription.updated, customer.subscription.deleted.
STRIPE_WEBHOOK_SECRET=

# Vercel Production: copy vercel-production.env.example → vercel-production.env, fill, import in Vercel.
