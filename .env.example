# Copy to .env.local for local development (never commit secrets).

# Supabase — create a project at https://supabase.com and paste keys from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: create a Storage bucket named `projects` for JSON saves (see src/lib/supabase/projectStorage.ts)
