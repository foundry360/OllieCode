# Stripe catalog import (products + recurring prices only)
# ==========================================================
# 1. Copy this file to `import.env` (gitignored) at the repo root.
# 2. Set STRIPE_SECRET_KEY to your **live** secret key (`sk_live_…`).
# 3. Set STRIPE_IMPORT_CONFIRM_LIVE=1 (required so live runs are explicit).
# 4. From repo root: `npm run stripe:import-catalog`
# 5. Copy the script output (`STRIPE_PRICE_*=price_…`) into Vercel → Project →
#    Settings → Environment Variables (Production). You do not need to put
#    `STRIPE_SECRET_KEY` in that same bulk file if it is already configured there.
#
# Defaults match `src/lib/plans/planCards.ts` (USD). Override with *_CENTS vars if needed.

STRIPE_SECRET_KEY=
STRIPE_IMPORT_CONFIRM_LIVE=

# Optional amount overrides (integer cents, USD)
# STARTER_MONTHLY_CENTS=700
# STARTER_YEARLY_CENTS=7500
# FAMILY_MONTHLY_CENTS=1200
# FAMILY_YEARLY_CENTS=13000
