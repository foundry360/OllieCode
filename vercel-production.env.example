# Copy this file to `vercel-production.env`, fill in real values, then either:
#   • Import in Vercel → Settings → Environment Variables, or
#   • From the repo root: `npm run vercel:env:production` (requires `npx vercel link` first).
# Do not commit `vercel-production.env` (it is gitignored).
#
# Supabase Auth: set Site URL + Redirect URLs to your production origin (e.g. https://your-app.vercel.app).

# --- Required ---
NEXT_PUBLIC_SUPABASE_URL=
# Use anon OR publishable key (see .env.example); only one public key is needed.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
PENDING_SIGNUP_SECRET=

# --- Recommended ---
NEXT_PUBLIC_AUTH_EMAIL_DOMAIN=

# --- Stripe (subscriptions; Price IDs from Dashboard → Products) ---
# Use one Product per plan (Starter, Family) with two recurring prices each (month + year); see .env.example.
# To create Products + Prices in live Stripe and print these IDs: `import.env.example` → `npm run stripe:import-catalog`.
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# NEXT_PUBLIC_SITE_URL=https://your-production-domain.com
# STRIPE_PRICE_STARTER_MONTHLY=
# STRIPE_PRICE_STARTER_YEARLY=
# STRIPE_PRICE_FAMILY_MONTHLY=
# STRIPE_PRICE_FAMILY_YEARLY=
# STRIPE_WEBHOOK_SECRET=whsec_...

# --- Optional: admin usernames (comma-separated); DB profiles.is_admin also grants admin ---
# OLLIE_ADMIN_USERNAMES=

# --- Optional: Resend (parent approval email); leave empty to skip sending ---
# EMAIL_API_URL=https://api.resend.com/emails
# EMAIL_API_KEY=
# EMAIL_FROM=
